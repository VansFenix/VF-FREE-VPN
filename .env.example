# Vercel Environment Variables (установить в Vercel Dashboard → Project Settings → Environment Variables)

BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=wvfrobot
ADMIN_LOGIN=your_admin_login
ADMIN_PASSWORD=your_admin_password
API_KEY=your_api_key_for_frontend

# Upstash Redis (https://upstash.com — бесплатный тир 10k запросов/день)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
